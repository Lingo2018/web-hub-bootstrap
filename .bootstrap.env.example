# bootstrap-vps-deploy.sh config template
# Copy this to ~/.bootstrap.env on the VPS (or let the script generate
# the template on first run), fill in values, then re-run the script.

# ── REQUIRED ──────────────────────────────────────────
DOMAIN=hub.acme-corp.com             # must already have DNS A-record pointing to this VPS

# ── REPO ACCESS ──────────────────────────────────────
WEB_HUB_REPO=https://github.com/Lingo2018/web-hub.git
# For private repos, set up a deploy key on the VPS first and use:
# WEB_HUB_REPO=git@github.com:Lingo2018/web-hub.git

# ── OPTIONAL ─────────────────────────────────────────
DEPLOYMENT_YAML=deployments/acme-corp/deployment.yaml   # set after you scp this file in
WEB_HUB_PORT=3800
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
BACKUP_ROOT=/tmp/web-hub-backup-staging                 # local staging; rclone moves to S3 separately
SKIP_CADDY=false
